# ═══════════════════════════════════════════════════
# Project IronMAn — Jarvis Command Center
# Copy this to .env and fill in your values.
# ═══════════════════════════════════════════════════

# ── Database ────────────────────────────────────────
# PostgreSQL (default for production on macOS via Homebrew)
DATABASE_URL=postgresql://localhost/ironman_jarvis

# SQLite fallback (comment out DATABASE_URL above and use this for quick start):
# DATABASE_URL=sqlite:///./ironman.db

# ── Ollama (local LLM) ──────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Lighter model options for 8GB RAM Macs:
# OLLAMA_MODEL=phi3
# OLLAMA_MODEL=qwen2.5:3b

# ── Application ─────────────────────────────────────
DEBUG=false
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── CORS ────────────────────────────────────────────
# Set to true when the Next.js frontend is deployed remotely (Vercel, Netlify, etc.)
# and the backend is accessed via a tunnel (Tailscale, Cloudflare Tunnel, ngrok).
# With CORS_ALLOW_ALL_ORIGINS=true, credentials (cookies) are disabled — use token auth.
CORS_ALLOW_ALL_ORIGINS=false
# Alternatively, add your deployed frontend URL to the allowlist:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app

# ── Voice / Speech-to-Text ──────────────────────────
# Groq Whisper: free tier, very fast, Alexa-quality accuracy.
# Get key at: https://console.groq.com/keys
# After adding, set stt_provider=groq via PATCH /voice/settings
GROQ_API_KEY=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

# ── Ollama token limits (optional) ──────────────────
# Caps each LLM generation to N tokens. 0 = model default (no cap).
# Lower values (e.g. 512) speed up responses at the cost of completeness.
OLLAMA_MAX_TOKENS=0

# ── Google OAuth (Gmail + Calendar integration) ─────
# How to get these:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project → APIs & Services → Credentials
#   3. Create OAuth 2.0 Client ID → Desktop or Web application
#   4. Add authorized redirect URI: http://localhost:8000/integrations/google/callback
#   5. Enable: Gmail API, Google Calendar API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# ── Claude API (optional — for claude-agent service) ─
# ANTHROPIC_API_KEY=sk-ant-...

# ── Ports (override if default ports are in use) ────
# API_PORT=8000
# WEB_PORT=3000
